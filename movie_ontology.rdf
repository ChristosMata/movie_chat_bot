<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/chris/ontologies/2026/3/"
     xml:base="http://www.semanticweb.org/chris/ontologies/2026/3/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/"/>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/directedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/hasDirected"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Director"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/hasDirected">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/directedBy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Director"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/hasPlayed">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Actor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/hasTheme">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Theme"/>
    </owl:ObjectProperty>

    <!-- Data Properties -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/movieTitle">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/personName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Actor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Director"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/releaseYear">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/rating">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/hasGenre">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Classes -->

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/CinemaContent">
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/CinemaPerson">
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/Movie">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/CinemaContent"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/Actor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/CinemaPerson"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/Director">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/chris/ontologies/2026/3/CinemaPerson"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/chris/ontologies/2026/3/Theme">
    </owl:Class>

